---
import Base from "../../../layouts/Base.astro";
import WatchGrid from "../../../components/WatchGrid.astro";
import { watches, watchesForCollection } from "../../../data/catalog";

export function getStaticPaths() {
  const seen = new Set<string>();
  const paths: { params: { brand: string; model: string } }[] = [];
  for (const w of watches) {
    const key = `${w.brand}/${w.model}`;
    if (seen.has(key)) continue;
    seen.add(key);
    paths.push({ params: { brand: w.brand, model: w.model } });
  }
  return paths;
}

const { brand, model } = Astro.params;
const list = watchesForCollection(brand!, model!);
---

<Base title={`${brand} ${model}`} description={`${brand} ${model} — ${list.length} pieces`}>
  <div class="mx-auto max-w-6xl px-4 py-10">
    <nav class="text-sm text-muted mb-4">
      <a href="/" class="hover:text-ink">Home</a>
      <span class="mx-1">/</span>
      <a href={`/brands/${encodeURIComponent(brand!)}`} class="hover:text-ink">{brand}</a>
      <span class="mx-1">/</span>
      <span class="text-ink">{model}</span>
    </nav>
    <h1 class="font-display text-4xl mt-1">{model}</h1>
    <p class="text-muted mt-2">{brand} · {list.length} pieces</p>

    <div class="mt-10">
      <WatchGrid watches={list} />
    </div>
  </div>
</Base>
