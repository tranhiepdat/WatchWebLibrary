---
import Base from "../layouts/Base.astro";
import { watches, brandsByCount, collectionsForBrand } from "../data/catalog";
import { photoPath, resized, srcset, CARD_WIDTHS } from "../data/images";

const brands = brandsByCount();
const total = watches.length;
const topBrand = brands[0]?.brand;
const topCollections = topBrand ? collectionsForBrand(topBrand).slice(0, 8) : [];
const brandSlug = (b: string) => encodeURIComponent(b);
---

<Base title="Home">
  <!-- Hero -->
  <section class="border-b border-line">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:py-24 text-center">
      <p class="eyebrow">Private Catalogue</p>
      <h1 class="font-display text-5xl sm:text-6xl mt-3">The Collection</h1>
      <p class="text-muted mt-4 max-w-xl mx-auto">
        A curated selection of {total} timepieces. Browse by house or explore the full collection.
      </p>
      <div class="mt-8 flex justify-center gap-3">
        <a href="/browse" class="inline-block px-6 py-3 bg-ink text-paper text-sm hover:bg-ink-soft transition-colors">
          Browse All
        </a>
      </div>
    </div>
  </section>

  <!-- Brand directory -->
  <section class="mx-auto max-w-6xl px-4 py-14">
    <h2 class="font-display text-3xl mb-8">Brands</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-4 gap-y-8">
      {
        brands.map(({ brand, count, cover }, i) => {
          const path = photoPath(cover.folder, cover.photos[0]);
          return (
            <a href={`/brands/${brandSlug(brand)}`} class="group block">
              <div class="aspect-square overflow-hidden bg-paper-2 border border-line">
                <img
                  src={resized(path, 600)}
                  srcset={srcset(path, CARD_WIDTHS)}
                  sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 300px"
                  width="600" height="600" alt={brand}
                  loading={i < 4 ? "eager" : "lazy"}
                  decoding="async"
                  class="w-full h-full object-cover transition-opacity duration-300 group-hover:opacity-90"
                />
              </div>
              <div class="pt-3 flex items-baseline justify-between">
                <h3 class="font-display text-lg">{brand}</h3>
                <span class="text-sm text-muted">{count}</span>
              </div>
            </a>
          );
        })
      }
    </div>
  </section>

  <!-- Featured collections (largest maison) -->
  {
    topCollections.length > 0 && (
      <section class="mx-auto max-w-6xl px-4 pb-16">
        <h2 class="font-display text-3xl mb-8">{topBrand} — Collections</h2>
        <div class="flex flex-wrap gap-3">
          {topCollections.map(({ model, count }) => (
            <a
              href={`/brands/${brandSlug(topBrand!)}/${encodeURIComponent(model)}`}
              class="px-4 py-2 border border-line hover:border-accent hover:text-accent-deep transition-colors text-sm"
            >
              {model} <span class="text-muted">· {count}</span>
            </a>
          ))}
        </div>
      </section>
    )
  }
</Base>
