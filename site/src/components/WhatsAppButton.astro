---
import { WHATSAPP_NUMBER, WHATSAPP_DEFAULT_TEXT } from "../config";

interface Props {
  product?: { name: string; brand: string; sku: string };
}
const { product } = Astro.props;

// Absolute URL of the current page (for the prefilled message).
const pageUrl = new URL(Astro.url.pathname, Astro.site ?? "https://watch-catalog-c0c.pages.dev").href;

const text = product
  ? `Hi! I'm interested in this piece: ${product.brand} ${product.name} (${product.sku}) — ${pageUrl}`
  : `${WHATSAPP_DEFAULT_TEXT} ${pageUrl}`;

const href = WHATSAPP_NUMBER
  ? `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(text)}`
  : null;
---

{
  href && (
    <a
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Chat on WhatsApp"
      class="fixed bottom-4 right-4 z-50 flex items-center gap-2 rounded-full bg-[#25D366] text-white shadow-lg pl-3 pr-4 py-3 hover:brightness-95 active:scale-95 transition"
    >
      <svg viewBox="0 0 32 32" width="22" height="22" fill="currentColor" aria-hidden="true">
        <path d="M16.001 3.2C8.94 3.2 3.2 8.94 3.2 16c0 2.26.6 4.46 1.73 6.4L3.2 28.8l6.56-1.72a12.7 12.7 0 0 0 6.24 1.62h.01c7.06 0 12.8-5.74 12.8-12.8 0-3.42-1.33-6.64-3.75-9.06A12.72 12.72 0 0 0 16.001 3.2Zm0 23.06h-.01a10.6 10.6 0 0 1-5.4-1.48l-.39-.23-3.9 1.02 1.04-3.8-.25-.4a10.56 10.56 0 0 1-1.62-5.63c0-5.86 4.77-10.62 10.63-10.62 2.84 0 5.5 1.11 7.51 3.12a10.55 10.55 0 0 1 3.11 7.51c0 5.86-4.77 10.62-10.62 10.62Zm5.83-7.96c-.32-.16-1.89-.93-2.18-1.04-.29-.11-.5-.16-.72.16-.21.32-.82 1.04-1.01 1.25-.19.21-.37.24-.69.08-.32-.16-1.35-.5-2.57-1.59-.95-.85-1.59-1.89-1.78-2.21-.19-.32-.02-.49.14-.65.15-.14.32-.37.48-.56.16-.19.21-.32.32-.53.11-.21.05-.4-.03-.56-.08-.16-.72-1.73-.99-2.37-.26-.62-.52-.54-.72-.55l-.61-.01c-.21 0-.56.08-.85.4-.29.32-1.11 1.09-1.11 2.66 0 1.57 1.14 3.08 1.3 3.29.16.21 2.25 3.43 5.45 4.81.76.33 1.36.53 1.82.68.77.24 1.46.21 2.01.13.61-.09 1.89-.77 2.16-1.52.27-.75.27-1.39.19-1.52-.08-.13-.29-.21-.61-.37Z" />
      </svg>
      <span class="text-sm font-medium">WhatsApp</span>
    </a>
  )
}
