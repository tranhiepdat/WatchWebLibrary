---
const links = [
  { href: "/", label: "Home" },
  { href: "/browse", label: "Browse All" },
];
const path = Astro.url.pathname;
---

<header class="border-b border-line bg-paper/90 backdrop-blur sticky top-0 z-30">
  <div class="mx-auto max-w-6xl px-4 h-16 flex items-center justify-between">
    <a href="/" class="font-display text-2xl leading-none tracking-wide">
      The Collection
    </a>
    <nav class="flex items-center gap-6 text-sm">
      {
        links.map((l) => (
          <a
            href={l.href}
            class:list={[
              "hover:text-accent-deep transition-colors",
              (l.href === "/" ? path === "/" : path.startsWith(l.href)) && "text-accent-deep",
            ]}
          >
            {l.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
